rem Copie para "definir_ambiente.bat" (ou configure via setx) e preencha.
rem NUNCA versione o arquivo com a senha real.

set FB_USER=SYSDBA
set FB_PASSWORD=coloque_a_senha_do_firebird
set FB_HOST=192.168.0.4
set FB_PORT=3050
set FB_DBPATH=G:\MGWare\db\autocom.fdb
set FB_CLIENT=C:\Program Files\Firebird\Firebird_3_0\fbclient.dll

rem Token que o app precisa enviar (invente uma senha forte e use a MESMA no easypanel em ERP_API_KEY)
set AGENT_TOKEN=troque_por_um_token_forte
set AGENT_PORT=8799
