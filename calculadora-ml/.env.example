# === Credenciais do seu app do Mercado Livre ===
# Copie este arquivo para ".env" (sem .example) e preencha com os SEUS valores.
# NUNCA compartilhe o .env nem cole o CLIENT_SECRET em lugar nenhum.
#
# Usamos o fluxo "client_credentials": basta o ID e a Secret do app.
# Não precisa de login de usuário, redirect URI nem PKCE.

# APP ID do seu app (DevCenter > Meus Aplicativos)
ML_CLIENT_ID=coloque_seu_app_id_aqui

# Secret Key do seu app (DevCenter > Meus Aplicativos > Editar)
ML_CLIENT_SECRET=coloque_sua_secret_key_aqui

# === Consulta de produto no ERP da loja (aba "Consultar produto") ===
# URL pública do túnel que aponta para o agente local (ver agente-erp/README.md).
# Ex.: https://loja-fantinel.trycloudflare.com  (ou seu domínio no túnel nomeado)
ERP_API_URL=
# Mesmo valor do AGENT_TOKEN definido no agente local.
ERP_API_KEY=

# === Fila de revisão (aba "Revisor") ===
# Pasta onde fica o banco SQLite da fila (revisao.db). Padrão: ./data
# Em produção (Docker/easypanel), aponte para um VOLUME montado (ex.: /app/data)
# senão a fila zera a cada redeploy.
DATA_DIR=
